# 4️⃣ Classes & Objects
class Student:
    def __init__(self, name, roll):
        self.name = name
        self.roll = roll
    
    def show(self):
        print(f"Student: {self.name}, Roll: {self.roll}")

s1 = Student("Bharti", 123)
s1.show()


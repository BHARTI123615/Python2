# 9️⃣ Decorators
def decorator(func):
    def wrapper():
        print("Before function")
        func()
        print("After function")
    return wrapper

@decorator
def say_hi():
    print("Hi!")

say_hi()

# 🔟 Generators
def gen_nums():
    for i in range(3):
        yield i

for val in gen_nums():
    print("Generated:", val)
